---
// Custom SocialIcons override — wraps Starlight's default and
// prepends a GitHub star-count badge next to the icon. Star count
// is fetched at build time via the public GitHub API; no token
// needed for the read-only repo endpoint.
import Default from '@astrojs/starlight/components/SocialIcons.astro';

// Fetch stars at build time. If the API call fails (rate limit,
// network), we just skip the badge — the icon still renders.
let stars: string | null = null;
try {
  const res = await fetch(
    'https://api.github.com/repos/russellromney/honker',
    { headers: { 'User-Agent': 'honker-site-build' } },
  );
  if (res.ok) {
    const data = await res.json();
    const n = data.stargazers_count;
    if (typeof n === 'number') {
      stars = n >= 1000 ? `${(n / 1000).toFixed(1)}k` : String(n);
    }
  }
} catch {
  // No stars badge — not an error.
}
---

<div class="honker-social">
  {stars && (
    <a
      class="honker-stars"
      href="https://github.com/russellromney/honker"
      aria-label={`${stars} GitHub stars`}
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="currentColor"
        width="14"
        height="14"
        aria-hidden="true"
      >
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z"/>
      </svg>
      <span>{stars}</span>
    </a>
  )}
  <Default><slot /></Default>
</div>

<style>
  .honker-social {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .honker-stars {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.25rem;
    font-size: var(--sl-text-xs);
    font-weight: 500;
    color: var(--sl-color-text);
    text-decoration: none;
    line-height: 1;
    white-space: nowrap;
  }
  .honker-stars:hover {
    color: var(--sl-color-accent-high);
    border-color: var(--sl-color-accent);
    background: var(--sl-color-gray-6);
  }
  .honker-stars svg {
    flex-shrink: 0;
  }
  /* On narrow screens the header gets tight — hide the star badge
     but keep the icon. */
  @media (max-width: 50rem) {
    .honker-stars { display: none; }
  }
</style>
